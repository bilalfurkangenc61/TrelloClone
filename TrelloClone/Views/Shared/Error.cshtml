<!-- Views/Shared/Hata.cshtml -->
@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="container-fluid py-5 text-center px-md-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="mb-4">
                <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size: 4rem;"></i>
            </div>
            <h1 class="display-4">Ups! Bir Hata Oluştu</h1>
            <h2 class="text-danger mb-4">Bir şeyler yanlış gitti</h2>

            @if (Model.ShowRequestId)
            {
                <p class="text-muted mb-4">
                    <strong>İstek ID:</strong> <code>@Model.RequestId</code>
                </p>
            }

            <div class="mb-5">
                <p class="lead">
                    Verdiğimiz rahatsızlık için özür dileriz. Lütfen daha sonra tekrar deneyin veya sorun devam ederse destek ekibimizle iletişime geçin.
                </p>
            </div>

            <div>
                <a href="/" class="btn btn-primary btn-lg">Ana Sayfaya Dön</a>
            </div>
        </div>
    </div>
</div>