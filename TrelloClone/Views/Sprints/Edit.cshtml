@model TrelloClone.Models.Sprint
@{
    ViewData["Title"] = "Sprint Düzenle";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">Sprint Düzenle</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="BoardId" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label"></label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label"></label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Goal" class="form-label"></label>
                            <textarea asp-for="Goal" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Goal" class="text-danger"></span>
                            <div class="form-text">Sprint için ana hedef veya misyon belirtin</div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                            <div class="form-text">Eğer işaretlenirse, diğer aktif sprintler pasif yapılacaktır.</div>
                        </div>

                        <div class="mb-3 form-check">
                            <input asp-for="IsCompleted" class="form-check-input" />
                            <label asp-for="IsCompleted" class="form-check-label"></label>
                            <div class="form-text">Sprint tamamlandı olarak işaretlensin mi?</div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Sprint Detaylarına Dön
                            </a>
                            <div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check2-circle"></i> Kaydet
                                </button>
                                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger ms-2">
                                    <i class="bi bi-trash"></i> Sil
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}